{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

# brew is not on PATH during a fresh bootstrap
if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

{{ if eq .chezmoi.hostname "Dimitriss-MacBook-Pro" -}}
# aerospace's third-party tap must be trusted before brew will load casks from it
brew trust --tap nikitabobko/tap
{{ end -}}
brew bundle --file=/dev/stdin <<EOF
brew "btop"
brew "git"
brew "zsh"
cask "1password"
cask "font-monaspice-nerd-font"
cask "itsycal"
cask "visual-studio-code"
cask "wezterm"
{{ if eq .chezmoi.hostname "Dimitriss-MacBook-Pro" -}}
tap "nikitabobko/tap"
cask "nikitabobko/tap/aerospace"
cask "firefox"
{{ else -}}
cask "google-chrome"
cask "docker-desktop"
cask "bruno"
cask "dbeaver-community"
{{ end -}}
EOF
{{ end -}}
