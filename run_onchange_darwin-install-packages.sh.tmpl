{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

# brew is not on PATH during a fresh bootstrap
if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

{{ $scope := ternary "personal" "work" .personal -}}
{{ range .packages -}}
{{ $rowScope := get . "scope" -}}
{{ if and (hasKey . "tap") (or (not $rowScope) (eq $rowScope $scope)) -}}
# third-party taps must be trusted before brew will load casks from them
brew trust --tap {{ get . "tap" }}
{{ end -}}
{{ end -}}
brew bundle --file=/dev/stdin <<EOF
{{ range .packages -}}
{{ $rowScope := get . "scope" -}}
{{ if or (not $rowScope) (eq $rowScope $scope) -}}
{{ with get . "tap" }}tap "{{ . }}"
{{ end -}}
{{ with get . "brew" }}brew "{{ . }}"
{{ end -}}
{{ with get . "cask" }}cask "{{ . }}"
{{ end -}}
{{ end -}}
{{ end -}}
EOF
{{ end -}}
