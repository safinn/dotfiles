{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

{{ $scope := ternary "personal" "work" .personal -}}
{{ $pkgs := list -}}
{{ range .packages -}}
{{ $rowScope := get . "scope" -}}
{{ if and (hasKey . "arch") (or (not $rowScope) (eq $rowScope $scope)) -}}
{{ $pkgs = append $pkgs (get . "arch") -}}
{{ end -}}
{{ end -}}
# Linux counterpart of the darwin packages script.
if command -v pacman >/dev/null 2>&1; then
    # bootstrap yay so one command can install both repo and AUR packages
    if ! command -v yay >/dev/null 2>&1; then
        sudo pacman -Syu --needed --noconfirm base-devel git
        yay_build=$(mktemp -d)
        git clone https://aur.archlinux.org/yay-bin.git "$yay_build"
        (cd "$yay_build" && makepkg -si --noconfirm)
        rm -rf "$yay_build"
    fi

    yay -Syu --needed --noconfirm {{ join " " $pkgs }}
elif command -v apt-get >/dev/null 2>&1; then
    sudo apt-get update
    sudo apt-get install -y zsh git
elif command -v dnf >/dev/null 2>&1; then
    sudo dnf install -y zsh git
else
    echo "warning: unrecognised package manager, install zsh manually" >&2
fi
{{ end -}}
